# Virtual Environment
.venv/
env/

# Python caching
__pycache__/
*.pyc

# Jupyter Notebooks
.ipynb_checkpoints/

# macOS
.DS_Store

# Data files (keep templates, ignore large mp3s)
data/raw_audio/*.mp3

# Working Excel — ignore backups, track the final populated workbook
data/working/*.bak
!data/working/*.xlsx

# Ignored intermediate outputs (keep directory structure via .gitkeep)
outputs/whisper_json/*
outputs/whisper_txt/*
outputs/logs/*
outputs/final_transcripts/*
!outputs/whisper_json/.gitkeep
!outputs/whisper_txt/.gitkeep
!outputs/logs/.gitkeep
!outputs/final_transcripts/.gitkeep

# Track audited CSVs (submission deliverables)
!outputs/review_csv/*.csv

